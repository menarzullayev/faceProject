# ── Python Cache ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
htmlcov/

# ── Local Configurations (Confidential) ───────────────────────────────────────
.env
.env*.local
.vscode/
.idea/
*.swp
*.swo

