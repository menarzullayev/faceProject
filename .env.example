# ==============================================================================
# Face Enrollment Service Configuration Template
# Copy this file to '.env' and adjust the paths to match your local setup:
#   cp .env.example .env
# ==============================================================================

# ── Face Detection Model ──────────────────────────────────────────────────────
# Path to the SCRFD 10G keypoint face detection ONNX model.
# Typically stored in your Ambarella Toolchain downloads or local models directory.
SCRFD_MODEL=models/scrfd_10g_bnkps.onnx

# ── Face Recognition Model ────────────────────────────────────────────────────
# Path to the ArcFace MobileFaceNet recognition ONNX model.
# Must be w600k_mbf.onnx to align with the recog_mbf_112.bin / arcface_mbf.bin running on camera.
ARCFACE_MODEL=models/w600k_mbf.onnx

# ── Biometric Quality Assessment Model (CR-FIQA) ──────────────────────────────
# Path to the Certainty Ratio Face Image Quality Assessment model (opset11).
CRFIQA_MODEL=models/crfiqa_s_quality_opset11.onnx

# ── Database Path ─────────────────────────────────────────────────────────────
# Path where the SQLite employee database file will be saved.
# Can be placed directly in the NFS directory for instant camera hot-reload,
# or in the enrollment service folder for local testing.
DB_PATH=/srv/nfs/employee.db
# DB_PATH=employee.db
